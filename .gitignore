# Cargo build output
target

# Test artifacts
**/*.db
**/postgres.rs.tmp*

# Rustfmt backup files
**/*.rs.bk

# MSVC debugging symbols
*.pdb

# Cargo mutants output
**/mutants.out*/

# LLVM coverage artifacts
coverage/
coverage.json
*.profraw
*.profdata

# IDEs
.idea/

# Dotdirs (allow .github/, .cargo/, and .hooks/)
.*/
!.cargo/
!.github/
!.claude/
!.hooks/
.claude/*
!.claude/CLAUDE.md

# Docs are markdown only
docs/**/
!docs/
!docs/architecture/
!docs/developing/
!docs/filters/
!docs/filters/http/
!docs/filters/http/*/
!docs/filters/tcp/
!docs/filters/tcp/*/
!docs/operating/
!docs/proposals/
